 "font_size": 14,
 "html": "{% if print_settings.repeat_header_footer %}\n<div id=\"header-html\">\n    {{ letter_head }}\n</div>\n{% endif %}\n\n<table width=\"100%\" style=\"font-size:8px\" >\n    {%if doc.supplier_address%}\n    {% set addr = frappe.get_doc(\"Address\", doc.supplier_address) %}\n    <tr>\n        <td width=\"25%\"><b class=\"color\">To</b><br>{{doc.supplier_name}}</td>\n        <td width=\"50%\"><b class=\"color\">Address : </b>{{addr.address_line1}} {{addr.custom_district}} {{addr.state}} {{addr.pincode}}</td>\n        <td width=\"25%\"><b class=\"color\">Address : </b>Level 2, Tower-4, World Trade Centre (WTC), Kharadi, Pune - 411014</td>\n    </tr>\n    <tr>\n        <td style=\"line-height:1px;\" width=\"25%\"><b class=\"color\">Mo. No. : </b>{{addr.phone or \"\"}}</td>\n        <td style=\"line-height:1px;\"><b class=\"color\">Purchase Order Type : </b>PO AGAINST INVENTORY</td>\n        <td style=\"line-height:1px;\"><b class=\"color\">Website : </b>www.shoption.in</td>\n    </tr>\n    <tr> \n        <td width=\"25%\"><b class=\"color\">PO Id : </b>{{doc.name}}</td>\n        <td><b class=\"color\">GST No : </b>{{addr.gstin}}</td>\n        <td><b class=\"color\">Mo No : </b>+91 9114151617  / <br>+91 9226514173</td>\n    </tr>\n    <tr style=\"line-height:5px;\">\n        <td width=\"25%\"><b class=\"color\">PO Date : </b>{{doc.transaction_date}}</td>\n        <td><b class=\"color\">Created By : </b></td>\n        <td><b class=\"color\">GST No: </b>27ABCCS4105L1ZB</td>\n    </tr>\n    {%endif %}\n</table>\n\n<table width=\"100%\" style=\"font-size:8px;text-align:center;\" border=1 class=\"border\">\n    <tr class=\"bgcolor\">\n        <td><b>Sr. No</b></td>\n        <td><b>Brand</b></td>\n        <td><b>Product</b></td>\n        <td><b>Bidding Amount</b></td>\n        <td><b>Qty</b></td>\n        <td><b>Total Amount</b></td>\n    </tr>\n    {% for row in doc.items%}\n    <tr>\n        <td>{{row.idx}}</td>\n        <td>{{row.brand}}</td>\n        <td>{{row.item_name}}</td>\n        <td>{{row.rate}}</td>\n        <td>{{row.qty}}</td>\n        <td>{{row.amount}}</td>\n    </tr>\n    {% endfor %}\n</table>\n\n<table width=\"100%\" style=\"font-size:8px;\" border=1 class=\"border\">\n    <tr>\n        <td style=\"line-height:1px\" ><b>Grand Total</b></td>\n        <td style=\"line-height:1px\" ><b>{{doc.grand_total}}</b></td>\n    </tr>\n    <tr>\n        <td style=\"line-height:1px\"><b>Amount in Words</b></td>\n        <td style=\"line-height:1px\"><b>{{doc.in_words}}</b></td>\n    </tr>\n</table> \n\n<table width=\"100%\" border=1 class=\"border\">\n    <!--{% set p_term = frappe.get_doc(\"Payment Terms Template\",doc.payment_terms_template)%}-->\n    <tr>\n        <td style=\"line-height:1px; font-size:8px;\"><b>Payment Terms : </b>Credit: 100.0% for 15.0 days</td>\n    </tr>\n    \n    {% if doc.tc_name%}\n    <tr><td style=\"line-height:1px; font-size:8px;\"><b>Terms & Conditions</b></td></tr>\n    {% set term = frappe.get_doc(\"Terms and Conditions\", doc.tc_name)%}\n    <tr>\n        <td style=\"line-height:1px; font-size:6.5px;\">{{term.terms}}</td>\n    </tr> \n    {%endif%}\n</table>\n\n {% if print_settings.repeat_header_footer %}\n\t<div id=\"footer-html\" class=\"visible-pdf\" >\n\t\t{% if not no_letterhead and footer %}\n\t\t\t<div class=\"letter-head-footer\">\n\t\t\t\t{{ footer }}\n\t\t\t</div>\n\t\t{% endif %}\n\t</div>\t\n{% endif %}",
